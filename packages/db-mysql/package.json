{
  "name": "@atscript/db-mysql",
  "version": "0.1.44",
  "description": "MySQL adapter for @atscript/db with mysql2 driver support.",
  "keywords": [
    "atscript",
    "database",
    "mysql"
  ],
  "homepage": "https://github.com/moostjs/atscript-db/tree/main/packages/db-mysql#readme",
  "bugs": {
    "url": "https://github.com/moostjs/atscript-db/issues"
  },
  "license": "MIT",
  "author": "Artem Maltsev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moostjs/atscript-db.git",
    "directory": "packages/db-mysql"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "asc -f dts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "devDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/typescript": "^0.1.43",
    "@uniqu/core": "^0.1.2",
    "mysql2": "^3.11.0",
    "unplugin-atscript": "catalog:"
  },
  "peerDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/db": "workspace:^",
    "@atscript/db-sql-tools": "workspace:^",
    "@atscript/typescript": "^0.1.43",
    "@uniqu/core": "^0.1.2",
    "mysql2": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    }
  }
}
