  },
  "license": "MIT",
  "author": "Artem Maltsev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moostjs/atscript-db.git",
    "directory": "packages/db-sql-tools"
  },
  "files": [
    "dist"
  ],
  "type": "module",
