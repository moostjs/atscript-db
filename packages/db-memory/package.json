{
  "name": "@atscript/db-memory",
  "version": "0.1.113",
  "description": "In-memory adapter for atscript-db.",
  "keywords": [
    "atscript",
    "database",
    "memory"
  ],
  "homepage": "https://github.com/moostjs/atscript-db/tree/main/packages/db-memory#readme",
  "bugs": {
    "url": "https://github.com/moostjs/atscript-db/issues"
  },
  "license": "MIT",
  "author": "Artem Maltsev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moostjs/atscript-db.git",
    "directory": "packages/db-memory"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "asc -f dts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "devDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/typescript": "catalog:",
    "unplugin-atscript": "catalog:"
  },
  "peerDependencies": {
    "@atscript/core": "catalog:",
    "@atscript/db": "workspace:^",
    "@atscript/typescript": "catalog:"
  }
}
